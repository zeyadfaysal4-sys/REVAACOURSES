<div class="card shadow border-0">
    <div class="card-header bg-primary text-white">
        <h4 class="mb-0">
            <i class="fas fa-user-graduate me-2"></i>Enrollments
        </h4>
    </div>

    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-hover align-middle">
                <thead class="table-dark">
                    <tr>
                        <th><i class="fas fa-user me-1"></i> Student</th>
                        <th><i class="fas fa-book me-1"></i> Course</th>
                        <th><i class="fas fa-calendar-alt me-1"></i> Enrollment Date</th>
                        <th><i class="fas fa-check-circle me-1"></i> Status</th>
                    </tr>
                </thead>

                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.Student.User.Name</td>

                            <td>
                                <span class="fw-bold text-primary">
                                    @item.Course.Title
                                </span>
                            </td>

                            <td>
                                @item.EnrollmentDate.ToString("dd/MM/yyyy")
                            </td>

                            <td>
                                @if (item.status)
                                {
                                    <span class="badge bg-success">
                                        Active
                                    </span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">
                                        Inactive
                                    </span>
                                }
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>