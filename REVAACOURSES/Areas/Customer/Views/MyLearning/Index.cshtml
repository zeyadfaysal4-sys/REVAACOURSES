@model IEnumerable<Enrollment>

@{
    ViewData["Title"] = "My Courses";
}

<div class="mycourses-bg">

    <div class="container py-5">

        <h1 class="page-title mb-3">
            📚 My Courses
        </h1>

        @if (!Model.Any())
        {
            <div class="alert alert-light shadow">
                <h5>You don't have any courses yet.</h5>
            </div>
        }
        else
        {
            <div class="row g-4">

                @foreach (var item in Model)
                {
                    <div class="col-lg-4 col-md-6">

                        <div class="course-card">

                            <div class="course-body">

                                <h4>@item.Course.Title</h4>

                                <p>@item.Course.Description</p>

                                <a asp-action="Lessons"
                                   asp-route-courseId="@item.CourseId"
                                   class="btn btn-primary w-100">
                                    Open Course
                                </a>

                            </div>

                        </div>

                    </div>
                }

            </div>
        }

    </div>

</div>

<style>

    .mycourses-bg {
        min-height: 100vh;
        background: url('/Images/background.jfif') center center / cover no-repeat fixed;
        padding: 40px 0;
    }

    .page-title {
        color: #fff;
        font-weight: 700;
        text-shadow: 2px 2px 10px rgba(0,0,0,.8);
    }

    .course-card {
        background: rgba(255,255,255,.95);
        border-radius: 18px;
        box-shadow: 0 10px 25px rgba(0,0,0,.2);
        transition: .3s;
        overflow: hidden;
    }

        .course-card:hover {
            transform: translateY(-8px);
            box-shadow: 0 18px 35px rgba(0,0,0,.3);
        }

    .course-body {
        padding: 20px;
    }

        .course-body h4 {
            font-weight: 700;
            margin-bottom: 15px;
            color: #222;
        }

        .course-body p {
            color: #555;
            min-height: 70px;
        }

    .btn-primary {
        border-radius: 10px;
        padding: 10px;
        font-weight: bold;
    }

</style>