@model REVAACOURSES.Models.Quiez

@{
    ViewData["Title"] = "Take Quiz";
}

<div class="container mt-5">

    <div class="card shadow">

        <div class="card-header bg-primary text-white">
            <h2>@Model.Title</h2>
        </div>

        <div class="card-body">

            <form asp-action="Submit" method="post">

                <input type="hidden" name="QuizId" value="@Model.Id" />

                @foreach (var question in Model.Questions)
                {
                    <div class="card mb-4">

                        <div class="card-header">
                            <strong>@question.QuestionText</strong>
                        </div>

                        <div class="card-body">

                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="radio"
                                       name="Answers[@question.Id]"
                                       value="A"
                                       id="A@question.Id" />

                                <label class="form-check-label" for="A@question.Id">
                                    A) @question.OptionA
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="radio"
                                       name="Answers[@question.Id]"
                                       value="B"
                                       id="B@question.Id" />

                                <label class="form-check-label" for="B@question.Id">
                                    B) @question.OptionB
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="radio"
                                       name="Answers[@question.Id]"
                                       value="C"
                                       id="C@question.Id" />

                                <label class="form-check-label" for="C@question.Id">
                                    C) @question.OptionC
                                </label>
                            </div>

                            <div class="form-check mb-2">
                                <input class="form-check-input"
                                       type="radio"
                                       name="Answers[@question.Id]"
                                       value="D"
                                       id="D@question.Id" />

                                <label class="form-check-label" for="D@question.Id">
                                    D) @question.OptionD
                                </label>
                            </div>

                        </div>

                    </div>
                }

                <button type="submit" class="btn btn-success">
                    Submit Quiz
                </button>

                <a asp-controller="MyLearning"
                   asp-action="Index"
                   class="btn btn-secondary">
                    Back
                </a>

            </form>

        </div>

    </div>

</div>