@using REVAACOURSES.ViewModels
@model RelatedWithCourse

<section class="py-5">
    <div class="container px-4 px-lg-5 my-5">
        <div class="row gx-4 gx-lg-5 align-items-center">

            <div class="col-md-6">
                <img class="card-img-top mb-5 mb-md-0"
                     src="~/Images/CourseImages/@Model.Course.Img"
                     alt="..." />
            </div>

            <div class="col-md-6">

                <div class="small mb-1">@Model.Course.Category.Name</div>

                <h1 class="display-5 fw-bolder">@Model.Course.Title</h1>

                <span class="course-price">
                    $ @Model.Course.Price
                </span>

                <p class="lead mt-3">@Model.Course.Description</p>

                <form asp-action="AddToCart" asp-controller="Cart">
                    <div class="d-flex">
                        <input name="courseId" value="@Model.Course.Id" hidden />

                        <button class="btn btn-outline-dark flex-shrink-0" type="submit">
                            <i class="bi-cart-fill me-1"></i>
                            Add to cart
                        </button>
                    </div>
                </form>

            </div>

        </div>
    </div>
</section>

<!-- Related items section -->
<section class="py-5 bg-light">

    <div class="container px-4 px-lg-5 mt-5">

        <h2 class="fw-bolder mb-4">Related Products</h2>

        <div class="row gx-4 gx-lg-5 row-cols-2 row-cols-md-3 row-cols-xl-4 justify-content-center">

            @foreach (var item in Model.RelatedCourses)
            {
                <div class="col mb-5">

                    <div class="card h-100">

                        <div class="badge bg-dark text-white position-absolute"
                             style="top:0.5rem; right:0.5rem;">
                            @item.Category.Name
                        </div>

                        <img class="card-img-top"
                             src="~/Images/CourseImages/@item.Img"
                             alt="..." />

                        <div class="card-body p-4">

                            <div class="text-center">

                                <h5 class="fw-bolder">@item.Title</h5>

                                <span class="course-price-card">
                                    $ @item.Price
                                </span>

                            </div>

                        </div>

                        <div class="card-footer p-4 pt-0 border-top-0 bg-transparent">

                            <div class="text-center">
                                <a class="btn btn-outline-dark mt-auto"
                                   href="/Customer/Cart/AddToCart?CourseId=@item.Id">
                                    Add to cart
                                </a>
                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

</section>

<style>

    .small {
        color: white !important;
    }

    .display-5 {
        color: white !important;
    }

    .lead {
        color: white !important;
    }

    h2 {
        color: white !important;
    }

    .course-price {
        color: white !important;
        font-size: 1.5rem;
        font-weight: bold;
    }

    .course-price-card {
        color: #212529 !important;
        font-size: 1.2rem;
        font-weight: bold;
    }

    .btn-outline-dark {
        color: white;
        border-color: white;
    }

        .btn-outline-dark:hover {
            background: white;
            color: black;
        }

    .bg-light {
        background: transparent !important;
    }

    .card {
        background: rgba(255,255,255,.95);
        border: none;
        border-radius: 15px;
        box-shadow: 0 8px 20px rgba(0,0,0,.15);
    }

        .card h5 {
            color: #212529 !important;
        }

        .card .btn-outline-dark {
            color: #212529;
            border-color: #212529;
        }

            .card .btn-outline-dark:hover {
                background: #212529;
                color: white;
            }

</style>