@using REVAACOURSES.Models
@model List<Course>

@{
    ViewData["Title"] = "";
}

<header class="bg-dark py-5">
    <div class="container px-4 px-lg-5 my-5">
        <div class="text-center text-white">
            <h1 class="display-4 fw-bolder">Welcome to in REVAA_COURSES</h1>
            <p class="lead fw-normal text-white-50 mb-0">
                With this shop hompeage template
            </p>
        </div>
    </div>
</header>

<section class="py-4 filter-bar">
    <div class="container">

        <form>
            <div class="row justify-content-center align-items-center g-3">

                <div class="col-md-2">
                    <input type="text"
                           class="form-control"
                           placeholder="Title"
                           name="Title"
                           value="@ViewBag.Title">
                </div>

                <div class="col-md-2">
                    <input type="number"
                           class="form-control"
                           placeholder="Price"
                           name="Price"
                           value="@ViewBag.Price">
                </div>

                <div class="col-md-2">
                    <input type="date"
                           class="form-control"
                           name="CreatedAt"
                           value="@ViewBag.CreatedAt">
                </div>

                <div class="col-md-2">
                    <select name="CategoryId" class="form-select">
                        <option>--Select Category--</option>

                        @foreach (var item in ViewBag.Categories)
                        {
                            @if (item.CategoryId == ViewBag.CategoryId)
                            {
                                <option value="@item.CategoryId" selected>
                                    @item.Name
                                </option>
                            }
                            else
                            {
                                <option value="@item.CategoryId">
                                    @item.Name
                                </option>
                            }
                        }
                    </select>
                </div>

                <div class="col-md-2">
                    <button type="submit" class="btn btn-dark w-100">
                        Filter
                    </button>
                </div>

            </div>
        </form>

    </div>
</section>

<section class="py-3">
    <div class="container px-4 px-lg-5 mt-5">

        <div class="row gx-4 gx-lg-5 row-cols-1 row-cols-md-2 row-cols-lg-3 justify-content-center">

            @foreach (var item in Model)
            {
                <div class="col mb-4">

                    <div class="card h-100 shadow-sm">

                        <!-- Category -->
                        <div class="badge bg-dark text-white position-absolute"
                             style="top:10px;right:10px">
                            @item.Category.Name
                        </div>

                        <!-- Image -->
                        <img src="~/Images/CourseImages/@item.Img"
                             class="card-img-top course-img"
                             alt="@item.Title" />

                        <!-- Details -->
                        <div class="card-body d-flex flex-column text-center">

                            <h5 class="fw-bolder">
                                @item.Title
                            </h5>

                            <p class="card-text description">
                                @item.Description
                            </p>

                            <h5 class="fw-bolder">
                                @item.CreatedAt.ToString("MM/dd/yyyy")
                            </h5>

                            <h5 class="mb-3">
                                $ @item.Price
                            </h5>

                            <div class="mt-auto">
                                <a class="btn btn-outline-dark"
                                   href="/Customer/Home/CourseDetails/@item.Id">
                                    View
                                </a>
                            </div>

                        </div>

                    </div>

                </div>
            }

        </div>

    </div>

    <!-- Pagination -->
    <nav aria-label="Page navigation example">
        <div class="d-flex justify-content-center align-items-center">
            <ul class="pagination">

                <li class="page-item @(ViewBag.CurrentPage == 1 ? "disabled" : "")">
                    <a class="page-link"
                       asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage - 1)">
                        Previous
                    </a>
                </li>

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(ViewBag.CurrentPage == i ? "active" : "")">
                        <a class="page-link"
                           asp-area="Customer"
                           asp-controller="Home"
                           asp-action="Index"
                           asp-route-page="@i">
                            @i
                        </a>
                    </li>
                }

                <li class="page-item @(ViewBag.CurrentPage == ViewBag.TotalPages ? "disabled" : "")">
                    <a class="page-link"
                       asp-area="Customer"
                       asp-controller="Home"
                       asp-action="Index"
                       asp-route-page="@(ViewBag.CurrentPage + 1)">
                        Next
                    </a>
                </li>

            </ul>
        </div>
    </nav>

</section>

<style>
    .card{
        height:100%;
        border-radius:15px;
    }

    .course-img{
        height:300px;
        object-fit:cover;
    }

    .card-body{
        display:flex;
        flex-direction:column;
    }

    .description{
        height:48px;
        overflow:hidden;
        display:-webkit-box;
        -webkit-line-clamp:2;
        -webkit-box-orient:vertical;
    }

    .mt-auto{
        margin-top:auto;
    }
</style>